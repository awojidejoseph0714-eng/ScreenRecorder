<Window x:Class="ScreenRecorder.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Screen Recorder Settings" Height="620" Width="460"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        ResizeMode="NoResize" WindowStyle="None"
        AllowsTransparency="True">
    
    <Window.Resources>
        <!-- Modern Scrollbar Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2B2B2B"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" CornerRadius="6" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="#888888"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="#888888"/>
                                <Setter Property="Background" Value="#1A1A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" Value="#444444"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Background" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#555555"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" Value="#666666"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Background" Value="#777777"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#202020" CornerRadius="12" BorderThickness="1" BorderBrush="#444444">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title Bar -->
                <RowDefinition Height="*"/>    <!-- Settings Body -->
                <RowDefinition Height="Auto"/> <!-- Footer Actions -->
            </Grid.RowDefinitions>

            <!-- 1. Header (Custom Title Bar Window Drag handle) -->
            <Grid Grid.Row="0" Margin="0,0,0,15" MouseDown="TitleBar_MouseDown">
                <TextBlock Text="SETTINGS" FontSize="16" FontWeight="Bold" Foreground="#CCCCCC" VerticalAlignment="Center"/>
                <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" Foreground="#888888" Padding="6,2" Click="CancelButton_Click" VerticalAlignment="Center"/>
            </Grid>

            <!-- 2. Settings Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
                <StackPanel>
                    
                    <!-- Buffer Directory -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Hidden Buffer Directory (Stores temporary recordings &amp; index DB)" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#CCCCCC"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtBufferDir" Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <Button x:Name="BtnBrowseBuffer" Content="Browse..." Grid.Column="1" Click="BrowseBufferButton_Click" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>

                    <!-- Saved Directory -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Saved Clips Export Directory (Public Video Folder)" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#CCCCCC"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtSavedDir" Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <Button x:Name="BtnBrowseSaved" Content="Browse..." Grid.Column="1" Click="BrowseSavedButton_Click" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>

                    <!-- Buffer Hours -->
                    <StackPanel Margin="0,0,0,15">
                        <Grid>
                            <TextBlock Text="Rolling Buffer Length" FontWeight="SemiBold" Foreground="#CCCCCC"/>
                            <TextBlock x:Name="LblBufferText" Text="24 Hours" HorizontalAlignment="Right" Foreground="#FFFFFF" FontWeight="Bold"/>
                        </Grid>
                        <Slider x:Name="SldBufferHours" Minimum="1" Maximum="168" Value="24" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,5,0,2" ValueChanged="BufferHours_ValueChanged"/>
                        <TextBlock x:Name="LblBufferSpaceEstimate" Text="Est. space: ~36 GB (~1.5 GB/hour)" FontSize="11" Foreground="#888888"/>
                    </StackPanel>

                    <!-- Disk Space Info -->
                    <StackPanel Margin="0,5,0,15">
                        <Grid>
                            <TextBlock Text="Target Drive Space" FontSize="11" Foreground="#CCCCCC"/>
                            <TextBlock x:Name="LblDiskSpace" Text="250 GB Free / 500 GB Total" FontSize="11" HorizontalAlignment="Right" Foreground="#CCCCCC"/>
                        </Grid>
                        <ProgressBar x:Name="PrgDiskSpace" Height="6" Background="#2B2B2B" Foreground="#88D49E" BorderThickness="0" Margin="0,4,0,2" Minimum="0" Maximum="100"/>
                        <TextBlock x:Name="LblDiskWarning" Text="⚠️ Warning: Free space is low on selected drive!" FontSize="11" Foreground="#FFCC00" Visibility="Collapsed" FontWeight="Bold"/>
                    </StackPanel>

                    <Separator Background="#333333" Margin="0,0,0,15"/>

                    <!-- Options checkboxes -->
                    <StackPanel Margin="0,0,0,15">
                        <CheckBox x:Name="ChkEnableOcr" Content="Index Screen Text (Enable Search)" Foreground="#FFFFFF" IsChecked="True" Margin="0,0,0,10"/>
                        <CheckBox x:Name="ChkShowBorder" Content="Show Border Recording Indicator" Foreground="#FFFFFF" IsChecked="True" Margin="0,0,0,10"/>
                        <CheckBox x:Name="ChkAutoUpdate" Content="Check for updates automatically on startup" Foreground="#FFFFFF" IsChecked="True"/>
                    </StackPanel>

                    <!-- Monitor selection -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Record Monitor" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#CCCCCC"/>
                        <ComboBox x:Name="CmbMonitors" Background="#2B2B2B" Foreground="#FFFFFF" BorderBrush="#444444" Padding="6,4"/>
                    </StackPanel>

                    <Separator Background="#333333" Margin="0,0,0,15"/>

                    <!-- Excluded Processes -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Excluded Apps (One process name per line, e.g. chrome, notepad)" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#CCCCCC"/>
                        <TextBox x:Name="TxtExcludedApps" Height="100" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Padding="6" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Danger Zone (Factory Reset / Wipe all Traces) -->
                    <StackPanel Margin="0,15,0,15">
                        <TextBlock Text="Danger Zone" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#FF5555"/>
                        <Border BorderBrush="#FF5555" BorderThickness="1" CornerRadius="6" Padding="12" Background="#2A1B1B">
                            <StackPanel>
                                <TextBlock Text="Wipe all local recordings, database search indexes, application configurations, and startup Registry keys. This deletes all traces of Screen Recorder from this user account."
                                           TextWrapping="Wrap" FontSize="11" Foreground="#FFCCCC" Margin="0,0,0,10" LineHeight="15"/>
                                <Button x:Name="BtnFactoryReset" Content="Factory Reset (Wipe All Data)" Click="FactoryResetButton_Click" Background="#FF5555" Foreground="#FFFFFF" Padding="12,6" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- 3. Footer Actions -->
            <Grid Grid.Row="2">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Click="CancelButton_Click" Width="80" Margin="0,0,10,0"/>
                    <Button Content="Save" Style="{StaticResource PrimaryButton}" Click="SaveButton_Click" Width="80"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
