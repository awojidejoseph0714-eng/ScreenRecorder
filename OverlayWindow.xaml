<Window x:Class="ScreenRecorder.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Recording Area" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" Cursor="Cross">
    
    <Canvas x:Name="OverlayCanvas" Background="#80000000"
            MouseDown="Canvas_MouseDown" MouseMove="Canvas_MouseMove" MouseUp="Canvas_MouseUp">
        
        <!-- Selection Area Border -->
        <Border x:Name="SelectionBorder" BorderBrush="#F38BA8" BorderThickness="1.5"
                Background="Transparent" Visibility="Collapsed"/>
        
        <!-- Size Tooltip -->
        <Border x:Name="TooltipBorder" Background="#1E1E2E" CornerRadius="4" Padding="6,4"
                BorderBrush="#313244" BorderThickness="1" Visibility="Collapsed">
            <TextBlock x:Name="TxtTooltip" Foreground="#CDD6F4" FontSize="11" FontWeight="Bold"/>
        </Border>

        <!-- Instruction Overlay -->
        <Border x:Name="InstructionBorder" Background="#E61E1E2E" CornerRadius="8" Padding="20,12"
                BorderBrush="#313244" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Select Recording Area" Foreground="#F38BA8" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Click and drag to select a region. Press ESC to cancel." Foreground="#CDD6F4" FontSize="12" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Canvas>
</Window>
