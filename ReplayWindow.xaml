<Window x:Class="ScreenRecorder.ReplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Replay &amp; Search Player" Height="700" Width="1020"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True" WindowStyle="None">

    <Window.Resources>
        <!-- Custom TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2B2B2B"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" CornerRadius="6" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="#888888"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="#888888"/>
                                <Setter Property="Background" Value="#1A1A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Buttons -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" Value="#444444"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Background" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#555555"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" Value="#666666"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Background" Value="#777777"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom ListBoxItem Style for Search Results -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" Value="#333333"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter Property="Background" Value="#444444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#202020" CornerRadius="10" BorderThickness="1" BorderBrush="#444444">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Menu bar -->
                <RowDefinition Height="Auto"/> <!-- Header drag / status -->
                <RowDefinition Height="*"/>    <!-- Player + Search Workspace -->
                <RowDefinition Height="Auto"/> <!-- Scrubber Timeline -->
                <RowDefinition Height="Auto"/> <!-- Controls Footer -->
            </Grid.RowDefinitions>

            <!-- 0. Menu Bar (VLC-style) -->
            <Menu Grid.Row="0" Background="#2B2B2B" Foreground="#FFFFFF" Margin="-15,-15,-15,10">
                <MenuItem Header="File" Foreground="#FFFFFF" Padding="12,5">
                    <MenuItem Header="Settings..." Click="MenuSettings_Click" Foreground="#000000"/>
                    <Separator/>
                    <MenuItem Header="Exit" Click="MenuExit_Click" Foreground="#000000"/>
                </MenuItem>
            </Menu>

            <!-- 1. Header Drag Bar / Status -->
            <Grid Grid.Row="1" Margin="0,0,0,10" MouseDown="TitleBar_MouseDown">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="SCREEN WORKSTATION PLAYER" FontSize="15" FontWeight="Bold" Foreground="#CCCCCC" VerticalAlignment="Center"/>
                    <TextBlock x:Name="LblCurrentPlayTime" Text="[No active video]" Margin="20,0,0,0" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" Foreground="#888888" Padding="6,2" Click="ExitButton_Click" VerticalAlignment="Center"/>
            </Grid>

            <!-- 2. Workspace Body -->
            <Grid Grid.Row="2" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>      <!-- Video Player -->
                    <ColumnDefinition Width="300"/>    <!-- Sidebar panel -->
                </Grid.ColumnDefinitions>

                <!-- Video viewport -->
                <Border Grid.Column="0" Background="#111111" CornerRadius="6" BorderThickness="1" BorderBrush="#333333" Margin="0,0,15,0">
                    <Grid>
                        <!-- Hardware Accelerated Drawing Video Canvas -->
                        <Image x:Name="VideoPlayerImage" Stretch="Uniform">
                            <Image.Source>
                                <DrawingImage x:Name="VideoPlayerDrawingImage"/>
                            </Image.Source>
                        </Image>

                        <!-- Large Play/Pause Overlay indicator when paused -->
                        <Border x:Name="BdrPausedOverlay" Background="#99111111" Visibility="Collapsed" CornerRadius="6">
                            <TextBlock Text="PAUSED" FontSize="22" FontWeight="Bold" Foreground="#CCCCCC" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Sidebar panel (OCR Search & Saved clips) -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Tab headers -->
                        <RowDefinition Height="*"/>    <!-- Content list -->
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnSearchTab" Content="Search OCR" Grid.Column="0" Margin="0,0,5,0" FontWeight="Bold" Background="#333333" Click="SearchTab_Click"/>
                        <Button x:Name="BtnPinnedTab" Content="Saved Clips" Grid.Column="1" Margin="5,0,0,0" Foreground="#888888" Click="PinnedTab_Click"/>
                    </Grid>

                    <!-- Search Panel Content -->
                    <Grid x:Name="GridSearchTab" Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Info Description -->
                            <RowDefinition Height="Auto"/> <!-- Search input -->
                            <RowDefinition Height="*"/>    <!-- Results -->
                        </Grid.RowDefinitions>

                        <!-- OCR harvesting explanation -->
                        <Border Grid.Row="0" Background="#2B2B2B" BorderBrush="#333333" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                            <TextBlock Text="🔍 Screen text is harvested locally every 2 seconds via Windows OCR and indexed in SQLite. Search keywords to jump to exact moments."
                                       TextWrapping="Wrap" FontSize="11" Foreground="#888888" LineHeight="15"/>
                        </Border>

                        <TextBox x:Name="TxtSearchQuery" Grid.Row="1" Margin="0,0,0,10" KeyUp="SearchQuery_KeyUp" ToolTip="Type search keyword and press Enter"/>
                        
                        <ListBox x:Name="LstSearchResults" Grid.Row="2" Background="Transparent" BorderThickness="0" SelectionChanged="LstSearchResults_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,2">
                                        <Grid>
                                            <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:MM/dd HH:mm:ss}'}" FontWeight="Bold" Foreground="#CCCCCC" FontSize="11"/>
                                        </Grid>
                                        <TextBlock Text="{Binding Text}" Foreground="#AAAAAA" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0" Height="Auto" MaxHeight="60"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <!-- Saved Clips Content -->
                    <Grid x:Name="GridPinnedTab" Grid.Row="1" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>    <!-- File List -->
                            <RowDefinition Height="Auto"/> <!-- Folder Actions -->
                        </Grid.RowDefinitions>

                        <ListBox x:Name="LstPinnedMoments" Grid.Row="0" Background="Transparent" BorderThickness="0" SelectionChanged="LstPinnedMoments_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4" Width="260">
                                        <StackPanel VerticalAlignment="Center" Margin="0,0,50,0">
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#CCCCCC" FontSize="11" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding CreationTime, StringFormat='{}{0:MM/dd HH:mm:ss}'}" Foreground="#888888" FontSize="10" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Button Content="Play" HorizontalAlignment="Right" Padding="8,3" VerticalAlignment="Center" Click="PlaySavedClip_Click"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Content="Open Saved Folder" Grid.Row="1" Margin="0,10,0,0" Click="OpenSavedFolder_Click"/>
                    </Grid>
                </Grid>
            </Grid>

            <!-- 3. Timeline Scrubber -->
            <Grid Grid.Row="3" Margin="0,0,0,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Slider x:Name="SldTimeline" Grid.Row="0" Minimum="0" Maximum="100" Value="0" 
                        IsSelectionRangeEnabled="True" SelectionStart="0" SelectionEnd="0"
                        Background="#333333" Foreground="#555555"
                        ValueChanged="SldTimeline_ValueChanged" 
                        PreviewMouseDown="SldTimeline_PreviewMouseDown" 
                        PreviewMouseUp="SldTimeline_PreviewMouseUp" Height="22" VerticalAlignment="Center"/>
                
                <Grid Grid.Row="1" Margin="2,2,2,0">
                    <TextBlock x:Name="LblTimelineStart" Text="10:00 AM" FontSize="11" Foreground="#888888"/>
                    <TextBlock x:Name="LblClipRange" Text="Select range by marking keyframes" FontSize="11" Foreground="#CCCCCC" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="LblTimelineEnd" Text="11:00 AM" FontSize="11" Foreground="#888888" HorizontalAlignment="Right"/>
                </Grid>
            </Grid>

            <!-- 4. Controls Footer -->
            <Grid Grid.Row="4">
                <!-- Left aligned playback items -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="⏪ 5m" Click="Rewind5m_Click" Width="60" Margin="0,0,8,0"/>
                    <Button Content="⏪ 30s" Click="Rewind30s_Click" Width="60" Margin="0,0,8,0"/>
                    <Button x:Name="BtnPlayPause" Content="⏸ Pause" Click="PlayPause_Click" Width="80" Margin="0,0,8,0"/>
                    <Button Content="30s ⏩" Click="Forward30s_Click" Width="60" Margin="0,0,8,0"/>
                    <Button Content="5m ⏩" Click="Forward5m_Click" Width="60" Margin="0,0,15,0"/>
                    
                    <Button x:Name="BtnRecordToggle" Content="🔴 Recording" Click="RecordToggle_Click" Width="105" Foreground="#FF5555" FontWeight="Bold"/>
                </StackPanel>

                <!-- Right aligned clipping items -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnMarkStart" Content="[ Mark Start" Click="MarkStart_Click" Width="90" Margin="0,0,8,0"/>
                    <Button x:Name="BtnMarkEnd" Content="Mark End ]" Click="MarkEnd_Click" Width="90" Margin="0,0,8,0"/>
                    <Button x:Name="BtnSaveClip" Content="💾 Save Clip" Style="{StaticResource ActionButton}" Click="SaveClip_Click" Width="100"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
