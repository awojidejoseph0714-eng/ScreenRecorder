<Window x:Class="ScreenRecorder.ReplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Replay &amp; Search Player" Height="680" Width="980"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True" WindowStyle="None">

    <Window.Resources>
        <!-- Custom TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" CornerRadius="6" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="#F5C2E7"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="#F38BA8"/>
                                <Setter Property="Background" Value="#1E1E2E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Buttons -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" Value="#45475A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Background" Value="#585B70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#F38BA8"/>
            <Setter Property="Foreground" Value="#11111B"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" Value="#F5C2E7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Background" Value="#EBA0B2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom ListBoxItem Style for Search Results -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" Value="#313244"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter Property="Background" Value="#45475A"/>
                                <Setter Property="BorderBrush" Value="#F38BA8"/>
                                <Setter Property="BorderThickness" Value="0,0,3,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#1E1E2E" CornerRadius="12" BorderThickness="1" BorderBrush="#313244">
        <Grid Margin="20">
            <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title Bar -->
            <RowDefinition Height="*"/>    <!-- Player + Search Workspace -->
            <RowDefinition Height="Auto"/> <!-- Scrubber Timeline -->
            <RowDefinition Height="Auto"/> <!-- Controls Footer -->
        </Grid.RowDefinitions>

        <!-- 1. Header drag bar -->
        <Grid Grid.Row="0" Margin="0,0,0,15" MouseDown="TitleBar_MouseDown">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="REPLAY &amp; SEARCH" FontSize="18" FontWeight="Bold" Foreground="#F38BA8" VerticalAlignment="Center"/>
                <TextBlock x:Name="LblCurrentPlayTime" Text="[No active video]" Margin="20,0,0,0" FontSize="12" Foreground="#A6ADC8" VerticalAlignment="Center"/>
            </StackPanel>
            <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" Foreground="#A6ADC8" Padding="6,2" Click="ExitButton_Click" VerticalAlignment="Center"/>
        </Grid>

        <!-- 2. Workspace Body -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>      <!-- Video Player -->
                <ColumnDefinition Width="280"/>    <!-- Search sidebar -->
            </Grid.ColumnDefinitions>

            <!-- Video viewport -->
            <Border Grid.Column="0" Background="#11111B" CornerRadius="8" BorderThickness="1" BorderBrush="#313244" Margin="0,0,15,0">
                <Grid>
                    <!-- Hardware Accelerated Drawing Video Canvas -->
                    <Image x:Name="VideoPlayerImage" Stretch="Uniform">
                        <Image.Source>
                            <DrawingImage x:Name="VideoPlayerDrawingImage"/>
                        </Image.Source>
                    </Image>

                    <!-- Large Play/Pause Overlay indicator when paused -->
                    <Border x:Name="BdrPausedOverlay" Background="#9911111B" Visibility="Collapsed" CornerRadius="8">
                        <TextBlock Text="PAUSED" FontSize="24" FontWeight="Bold" Foreground="#F9E2AF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Sidebar panel (OCR Search & Pinned clips) -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Tab headers -->
                    <RowDefinition Height="*"/>    <!-- Content list -->
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnSearchTab" Content="Search OCR" Grid.Column="0" Margin="0,0,5,0" FontWeight="Bold" Background="#45475A" Click="SearchTab_Click"/>
                    <Button x:Name="BtnPinnedTab" Content="Pinned Moments" Grid.Column="1" Margin="5,0,0,0" Foreground="#A6ADC8" Click="PinnedTab_Click"/>
                </Grid>

                <!-- Search Panel Content -->
                <Grid x:Name="GridSearchTab" Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Search input -->
                        <RowDefinition Height="*"/>    <!-- Results -->
                    </Grid.RowDefinitions>

                    <TextBox x:Name="TxtSearchQuery" Grid.Row="0" Margin="0,0,0,10" KeyUp="SearchQuery_KeyUp"/>
                    <ListBox x:Name="LstSearchResults" Grid.Row="1" Background="Transparent" BorderThickness="0" SelectionChanged="LstSearchResults_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,2">
                                    <Grid>
                                        <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:MM/dd HH:mm:ss}'}" FontWeight="Bold" Foreground="#F38BA8" FontSize="11"/>
                                        <TextBlock Text="{Binding OffsetSeconds, StringFormat='{}Offset: {0:F0}s'}" Foreground="#A6ADC8" FontSize="10" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <TextBlock Text="{Binding Text}" Foreground="#CDD6F4" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0" Height="Auto" MaxHeight="38"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- Pinned Moments Content -->
                <Grid x:Name="GridPinnedTab" Grid.Row="1" Visibility="Collapsed">
                    <ListBox x:Name="LstPinnedMoments" Background="Transparent" BorderThickness="0" SelectionChanged="LstPinnedMoments_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4" Width="240">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding StartTime, StringFormat='{}{0:MM/dd HH:mm:ss}'}" FontWeight="Bold" Foreground="#F5C2E7" FontSize="11"/>
                                        <TextBlock Text="{Binding FilePath}" Foreground="#A6ADC8" FontSize="9" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Button Content="Export" HorizontalAlignment="Right" Padding="6,2" VerticalAlignment="Center" Click="ExportPinned_Click"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>
        </Grid>

        <!-- 3. Timeline Scrubber -->
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <Slider x:Name="SldTimeline" Grid.Row="0" Minimum="0" Maximum="100" Value="0" ValueChanged="SldTimeline_ValueChanged" PreviewMouseDown="SldTimeline_PreviewMouseDown" PreviewMouseUp="SldTimeline_PreviewMouseUp" Height="22" VerticalAlignment="Center"/>
            
            <Grid Grid.Row="1" Margin="2,0">
                <TextBlock x:Name="LblTimelineStart" Text="10:00 AM" FontSize="11" Foreground="#BAC2DE"/>
                <TextBlock x:Name="LblTimelineEnd" Text="11:00 AM" FontSize="11" Foreground="#BAC2DE" HorizontalAlignment="Right"/>
            </Grid>
        </Grid>

        <!-- 4. Controls Footer -->
        <Grid Grid.Row="3">
            <!-- Left aligned playback items -->
            <StackPanel Orientation="Horizontal">
                <Button Content="⏪ 5 Min" Click="Rewind5m_Click" Width="80" Margin="0,0,8,0"/>
                <Button Content="⏪ 30 Sec" Click="Rewind30s_Click" Width="80" Margin="0,0,8,0"/>
                <Button x:Name="BtnPlayPause" Content="⏸ Pause" Click="PlayPause_Click" Width="80" Margin="0,0,8,0"/>
                <Button Content="30 Sec ⏩" Click="Forward30s_Click" Width="80" Margin="0,0,8,0"/>
                <Button Content="5 Min ⏩" Click="Forward5m_Click" Width="80"/>
            </StackPanel>

            <!-- Right aligned pinning items -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnPinMoment" Content="📌 Pin Segment" Style="{StaticResource ActionButton}" Click="PinMoment_Click" Width="120"/>
            </StackPanel>
        </Grid>
    </Grid>
    </Border>
</Window>
