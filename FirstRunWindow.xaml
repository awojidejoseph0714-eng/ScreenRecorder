<Window x:Class="ScreenRecorder.FirstRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome &amp; Setup" Height="420" Width="520"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize">

    <Border BorderBrush="#444444" BorderThickness="1" CornerRadius="10" Background="#202020">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title/Header -->
                <RowDefinition Height="*"/>    <!-- Content Area (Slides) -->
                <RowDefinition Height="Auto"/> <!-- Navigation Footer -->
            </Grid.RowDefinitions>

            <!-- 1. Header (Custom Window Drag handle) -->
            <Grid Grid.Row="0" Margin="0,0,0,15" MouseDown="Header_MouseDown">
                <TextBlock Text="SCREEN RECORDER SETUP" FontSize="14" FontWeight="Bold" Foreground="#CCCCCC" VerticalAlignment="Center"/>
                <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" Foreground="#888888" BorderThickness="0" Padding="6,2" Click="CloseButton_Click" VerticalAlignment="Center"/>
            </Grid>

            <!-- 2. Slides Workspace -->
            <Grid Grid.Row="1" Margin="0,0,0,15">
                
                <!-- Slide 1: Welcome & Intro -->
                <StackPanel x:Name="PanelSlide1" Visibility="Visible" VerticalAlignment="Center">
                    <TextBlock Text="Welcome to Screen Recorder v2" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" Foreground="#FFFFFF"/>
                    <TextBlock Text="Screen Recorder is a local-first, ambient DVR app. It records your desktop screen into a rolling temporary buffer on your own machine. You can review, search, and export clips from your session at any time."
                               TextWrapping="Wrap" FontSize="13" Foreground="#CCCCCC" LineHeight="18" Margin="0,0,0,15"/>
                    <TextBlock Text="🔒 100% Local and Private" FontSize="13" FontWeight="Bold" Foreground="#88D49E" Margin="0,0,0,5"/>
                    <TextBlock Text="No cloud uploads, no external AI servers, and no telemetry. All recordings, settings, and search indexes are stored directly on your computer."
                               TextWrapping="Wrap" FontSize="12" Foreground="#AAAAAA" LineHeight="16"/>
                </StackPanel>

                <!-- Slide 2: User Manual & Features -->
                <StackPanel x:Name="PanelSlide2" Visibility="Collapsed" VerticalAlignment="Center">
                    <TextBlock Text="Quick Usage Guide" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" Foreground="#FFFFFF"/>
                    
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="• Screen Search:" FontWeight="Bold" Foreground="#CCCCCC" Grid.Column="0" Margin="0,0,5,0"/>
                        <TextBlock Text="Text on screen is indexed every 2 seconds via Windows OCR so you can search for keywords later." TextWrapping="Wrap" FontSize="12" Foreground="#AAAAAA" Grid.Column="1"/>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="• App Exclusions:" FontWeight="Bold" Foreground="#CCCCCC" Grid.Column="0" Margin="0,0,5,0"/>
                        <TextBlock Text="Recording automatically pauses when private apps (e.g. browsers, password managers) are focused." TextWrapping="Wrap" FontSize="12" Foreground="#AAAAAA" Grid.Column="1"/>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="• Range Clipping:" FontWeight="Bold" Foreground="#CCCCCC" Grid.Column="0" Margin="0,0,5,0"/>
                        <TextBlock Text="Scrub the timeline, mark a Start and End keyframe, and click 'Save Clip' to export an MP4 to your Videos folder." TextWrapping="Wrap" FontSize="12" Foreground="#AAAAAA" Grid.Column="1"/>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="• Hidden Buffer:" FontWeight="Bold" Foreground="#CCCCCC" Grid.Column="0" Margin="0,0,5,0"/>
                        <TextBlock Text="The rolling buffer files are saved in AppData to keep them out of your daily workspace folders." TextWrapping="Wrap" FontSize="12" Foreground="#AAAAAA" Grid.Column="1"/>
                    </Grid>
                </StackPanel>

                <!-- Slide 3: Agreement & Autostart -->
                <StackPanel x:Name="PanelSlide3" Visibility="Collapsed" VerticalAlignment="Center">
                    <TextBlock Text="Terms &amp; Privacy Agreement" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" Foreground="#FFFFFF"/>
                    
                    <Border Background="#2B2B2B" BorderBrush="#3D3D3D" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,15">
                        <TextBlock Text="Privacy Policy: Screen Recorder captures your desktop screen locally. Screen frames and OCR data are processed and stored only on this device. By checking this, you agree not to distribute or use this tool to capture sensitive or unauthorized data (passwords, banking) belonging to third parties."
                                   TextWrapping="Wrap" FontSize="11" Foreground="#CCCCCC" LineHeight="16"/>
                    </Border>

                    <CheckBox x:Name="ChkAgree" Content="I agree to the local privacy policy and terms" Foreground="#FFFFFF" Margin="0,0,0,10" Checked="ChkAgree_Toggle" Unchecked="ChkAgree_Toggle" FontSize="12" VerticalAlignment="Center"/>
                    <CheckBox x:Name="ChkAutostart" Content="Start Screen Recorder automatically on Windows boot" Foreground="#CCCCCC" IsChecked="True" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>

            </Grid>

            <!-- 3. Navigation Footer -->
            <Grid Grid.Row="2" Margin="0,10,0,0">
                <Button x:Name="BtnBack" Content="Back" Width="80" HorizontalAlignment="Left" Visibility="Collapsed" Click="BtnBack_Click" Background="#333333" Foreground="#FFFFFF" BorderBrush="#444444" Padding="6,4"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnNext" Content="Next" Width="80" Click="BtnNext_Click" Background="#333333" Foreground="#FFFFFF" BorderBrush="#444444" Padding="6,4"/>
                    <Button x:Name="BtnStart" Content="Start Recording Buffer" Click="BtnStart_Click" Visibility="Collapsed" IsEnabled="False" Background="#444444" Foreground="#FFFFFF" BorderBrush="#555555" Padding="12,4"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
